{
  "name": "containercode-advisory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:performance": "ANALYZE=true next dev",
    "build": "npx @opennextjs/cloudflare@latest build",
    "build:cloudflare": "npx @opennextjs/cloudflare@latest build",
    "build:pages": "npm run build",
    "deploy:cloudflare": "bash scripts/deploy-cloudflare.sh",
    "build:analyze": "ANALYZE=true next build",
    "bundle:analyze": "ANALYZE=true npm run build",
    "bundle:check": "node scripts/check-bundle-size.js",
    "preview:disabled": "echo 'OpenNext preview disabled'",
    "deploy:disabled": "echo 'OpenNext deploy disabled'",
    "upload:disabled": "echo 'OpenNext upload disabled'",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "next lint",
    "lint:security": "next lint --fix && npm audit",
    "fix:lint": "next lint --fix",
    "validate:env": "node scripts/validate-env.js",
    "optimize": "npm run validate:env && npm run bundle:check && npm run fix:lint",
    "deploy:safe": "npm run validate:env && npm run build:cloudflare && npx wrangler deploy",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "playwright test",
    "test:unit": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test smoke.spec.ts",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:performance": "lighthouse http://localhost:3000 --output=json --output-path=./performance-report.json",
    "test:phase1": "node scripts/test-phase1.js",
    "test:uat": "node tests/puppeteer-uat-enhanced.js",
    "test:stress": "node tests/stress-testing-newsletter.js",
    "test:api-smoke": "node tests/api-smoke-testing.js",
    "test:comprehensive": "npm run test:smoke && npm run test:uat && npm run test:stress && npm run test:api-smoke",
    "security:audit": "npm audit && npm audit fix",
    "performance:analyze": "npx @next/bundle-analyzer",
    "cache:clear": "rm -rf .next && npm run build",
    "monitor:vitals": "node scripts/monitor-vitals.js",
    "monitor:check": "tsx scripts/monitoring-alerts.ts check",
    "monitor:alerts": "tsx scripts/monitoring-alerts.ts test-alerts",
    "backup": "tsx scripts/backup-system.ts backup",
    "backup:restore": "tsx scripts/backup-system.ts restore",
    "backup:list": "tsx scripts/backup-system.ts list",
    "newsletter:generate": "tsx scripts/run-newsletter-automation.ts generate",
    "newsletter:generate:dry-run": "tsx scripts/run-newsletter-automation.ts generate --dry-run",
    "newsletter:test-apis": "tsx scripts/run-newsletter-automation.ts test-apis",
    "newsletter:validate": "tsx scripts/run-newsletter-automation.ts validate",
    "media:download": "tsx scripts/download-media.ts download",
    "media:hero": "tsx scripts/download-media.ts download --category=hero --count=10",
    "media:list": "tsx scripts/download-media.ts list",
    "media:summary": "tsx scripts/download-media.ts summary",
    "media:validate": "tsx scripts/download-media.ts validate",
    "media:cleanup": "tsx scripts/download-media.ts download --cleanup",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "images:download": "node scripts/download-images.js",
    "images:download-all": "tsx scripts/download-all-images.ts",
    "images:setup-complete": "npm run images:download-all download",
    "images:update": "node scripts/update-image-metadata.js",
    "images:components": "node scripts/update-image-components.js",
    "images:manage": "node scripts/autonomous-image-manager.js",
    "images:preoptimize": "node scripts/preoptimize-images.js",
    "images:setup": "npm run images:download && npm run images:update && npm run images:components && npm run images:preoptimize",
    "dev:fast": "npm run images:preoptimize && npm run dev",
    "images:optimize": "npm run images:manage",
    "images:cleanup": "npm run images:download-all cleanup",
    "deploy:staging": "wrangler pages deploy .next --project-name=containercode-staging",
    "deploy:production": "wrangler pages deploy .next --project-name=containercode-app",
    "health:check": "curl -f https://containercode.com/api/health",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:server": "cross-env ANALYZE=true BUNDLE_ANALYZE=server next build",
    "analyze:browser": "cross-env ANALYZE=true BUNDLE_ANALYZE=browser next build"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^3.3.2",
    "@next/bundle-analyzer": "^15.3.5",
    "@nextui-org/react": "^2.6.11",
    "@notionhq/client": "^2.3.0",
    "@opennextjs/cloudflare": "^1.5.1",
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@react-spring/web": "^10.0.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "dotenv": "^17.2.0",
    "framer-motion": "^12.23.3",
    "lucide-react": "^0.307.0",
    "next": "^14.0.0",
    "next-pwa": "^5.6.0",
    "node-fetch": "^2.7.0",
    "notion-client": "^6.16.0",
    "openai": "^5.9.0",
    "pexels": "^1.4.0",
    "prisma": "^6.11.1",
    "puppeteer": "^24.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.49.2",
    "react-hot-toast": "^2.5.2",
    "react-intersection-observer": "^9.16.0",
    "react-spring": "^10.0.1",
    "resend": "^2.1.0",
    "sharp": "^0.34.3",
    "tailwind-merge": "^2.6.0",
    "typescript": "^5.0.0",
    "web-vitals": "^5.0.3",
    "workbox-webpack-plugin": "^7.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^12.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.20.3",
    "wrangler": "^4.24.3"
  },
  "performance": {
    "budgets": {
      "bundle": "1MB",
      "lcp": "2.5s",
      "fcp": "1.8s",
      "cls": "0.1",
      "fid": "100ms",
      "ttfb": "800ms"
    }
  },
  "security": {
    "audit": {
      "level": "moderate",
      "exclude": []
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not ie 11"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
