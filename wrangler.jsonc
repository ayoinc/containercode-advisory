{
  "name": "containercode",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  
  "observability": {
    "logs": {
      "enabled": true
    }
  },
  
  // Non-secret config only. Secrets (NOTION_TOKEN, RESEND_API_KEY,
  // DEEPSEEK_API_KEY, GEMINI_API_KEY, PEXELS_API_KEY, BRAVE_API_KEY,
  // REVALIDATION_SECRET, ADMIN_API_KEY) are managed as Cloudflare Worker
  // secrets (dashboard / `wrangler secret put`) — never committed here.
  "vars": {
    "RESEND_DOMAIN": "containercode.club",
    "RESEND_EMAIL_FROM": "ContainerCode Advisory <hello@containercode.club>",
    "ADMIN_EMAIL": "ayoinc@me.com",
    "NOTION_DATABASE_SERVICES": "22ef9e48-4512-816b-8cdd-e9d1e0150946",
    "NOTION_DATABASE_BLOG_POSTS": "22ef9e48-4512-8116-91c3-fd6cd65520a1",
    "NOTION_DATABASE_NEWSLETTERS": "22ff9e48-4512-818e-bf90-c1d630503f2e",
    "NOTION_DATABASE_SUBSCRIBERS": "22ff9e48-4512-818c-8120-e37c3c296442",
    "NOTION_DATABASE_GENERATED_ARTICLES": "22ff9e48-4512-8153-80bd-fe94d869ff00",
    "NOTION_DATABASE_WEBSITE_PAGES": "22ff9e48-4512-81c2-9b40-ff7ae702a424",
    "NOTION_DATABASE_TRENDING_TOPICS": "22ff9e48-4512-81fc-9187-d5728a6f178e",
    "NOTION_DATABASE_EMAIL_CAMPAIGNS": "22ff9e48-4512-8171-b609-c88d8f0fff23",
    "NEXT_PUBLIC_SITE_URL": "https://containercode.club"
  },
  
  "assets": {
    "directory": ".open-next/assets",
    "binding": "STATIC_ASSETS"
  },
  
  // Newsletter automation bindings
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "newsletter-db-id",
      "database_id": "4d8f479a-069a-446d-9930-2e4bbf8dae77"
    }
  ],
  
  "r2_buckets": [
    {
      "binding": "IMAGES",
      "bucket_name": "blog-images"
    },
    {
      "binding": "R2_ASSETS",
      "bucket_name": "newsletter-assets"
    }
  ],
  
  "kv_namespaces": [
    {
      "binding": "KV_BINDING",
      "id": "ca3f3cbafbbc42c38c93c6b62b854ba1"
    }
  ],
  
  "ai": {
    "binding": "AI"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "containercode"
    }
  ]
}
